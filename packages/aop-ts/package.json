{
  "name": "@heybeaux/aop",
  "version": "0.1.0",
  "description": "Agent Observation Protocol (AOP) v0.1 — language-neutral cognitive observation types, projection helpers, and schema validator",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --shims --clean && node -e \"const fs=require('node:fs');fs.mkdirSync('dist/spec/v0.1',{recursive:true});fs.copyFileSync('../../spec/v0.1/agent-observation-event.schema.json','dist/spec/v0.1/agent-observation-event.schema.json');fs.mkdirSync('dist/spec/v0.2',{recursive:true});fs.copyFileSync('../../spec/v0.2/agent-observation-event.schema.json','dist/spec/v0.2/agent-observation-event.schema.json')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
